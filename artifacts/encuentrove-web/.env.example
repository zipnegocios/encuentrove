# Backend API base URL.
# In dev: leave empty — Vite proxy forwards /api/* to BACKEND_URL (set in vite.config.ts).
# In Docker: set BACKEND_URL for the nginx proxy_pass. VITE_API_BASE_URL overrides
#            the proxy if you want the browser to call the API directly.
VITE_API_BASE_URL=

# S3 bucket base URL for serving photos.
# When set, photo paths from the API are prefixed with this URL.
VITE_S3_BASE_URL=https://encuentrove-bucket.s3.us-east-1.amazonaws.com

# (Docker only) Backend URL used by the nginx proxy inside the container.
# BACKEND_URL=https://heart.encuentrove.online
